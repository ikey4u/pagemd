{
  "name": "pagemd-chrome-extension",
  "version": "0.2.0",
  "private": true,
  "description": "Convert any web page to Markdown",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --dev --watch",
    "build:js": "node esbuild.config.mjs --outdir=dist",
    "build:css": "node scripts/build.mjs --css-only",
    "build:wasm": "wasm-pack build --target web ./wasm",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/chrome": "^0.1.42",
    "@types/markdown-it": "^14.1.2",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.19.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.0"
  }
}
